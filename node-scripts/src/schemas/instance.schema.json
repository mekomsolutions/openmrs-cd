{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["maven"]
              },
              "mavenUrl": {
                "type": "string"
              },
              "value": {
                "type": "object",
                "required": ["artifactId", "groupId", "version"],
                "properties": {
                  "artifactId": { "type": "string" },
                  "groupId": { "type": "string" },
                  "packaging": { "type": "string" },
                  "version": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["docker"]
              },
              "value": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": { "type": "string" },
                  "tag": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["git"]
              },
              "gitUrl": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["file"]
              },
              "value": {
                "type": "string"
              },
              "destination": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "deployment": {
      "type": "object",
      "properties": {
        "hostDir": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "docker",
            "dockerCompose",
            "dockerComposeFromArtifact",
            "dockerComposeMaven",
            "dockerComposeGenericMaven",
            "k8s",
            "file"
          ]
        },
        "dockerComposeFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maintenanceUrl": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        },
        "host": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "ip": { "type": "string" },
            "user": { "type": "string" },
            "password": { "type": "string" },
            "sshKey": { "type": "string" },
            "port": { "type": ["string", "integer"] },
            "jumpHost": {
              "type": "object",
              "description": "Optional bastion for OpenSSH ProxyJump (-J). Omit for direct SSH.",
              "properties": {
                "ip": { "type": "string" },
                "user": { "type": "string" },
                "port": { "type": ["string", "integer"] }
              },
              "required": ["ip"],
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "port": {
          "type": ["string", "integer"]
        }
      }
    },
    "description": {
      "type": "string"
    },
    "group": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "properties": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "envVars": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    },
    "scripts": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "command": { "type": "string" }
            }
          }
        ]
      }
    },
    "uuid": {
      "type": "string",
      "pattern":
        "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": ["string", "number"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
